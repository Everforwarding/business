{
  "name": "glasses-shop",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node ./node_modules/vite/bin/vite.js build",
    "build:ci": "node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "generate-qr": "node tools/gen-qr.js",
    "generate-sitemap": "node tools/generate-sitemap.cjs",
    "postbuild": "npm run generate-sitemap",
