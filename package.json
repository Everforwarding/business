    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "release": "node tools/release.cjs"

  },
  "dependencies": {
    "axios": "^1.16.1",
    "cos-nodejs-sdk-v5": "^2.15.4",
    "mime": "^4.1.0",
