    "qrcode": "^1.5.4",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "gh-pages": "^6.3.0",
    "postcss": "^8.4.37",
    "tailwindcss": "^3.4.3",
    "vite": "^5.4.1"
  }
}

